# Upload and storage directories
UPLOAD_DIR=uploads
PROCESSED_DIR=processed

# Cleanup TTL in hours (0 = no cleanup)
CLEANUP_TTL_HOURS=24

# Maximum file size in MB
MAX_FILE_SIZE=100

# PicWish API Key (required)
PICWISH_API_KEY=wxonyvyt3y8gnkavq

# PicWish API URL (optional, defaults to standard endpoint)
# PICWISH_API_URL=https://api.picwish.com/v1/remove-background

# Default output format
OUTPUT_FORMAT=PNG

# Batch processing settings (for large volumes like 50,000 images)
BATCH_SIZE=500
MAX_CONCURRENT=10

# Compression defaults
DEFAULT_COMPRESSION_QUALITY=85
DEFAULT_MAX_DIMENSION=2048

