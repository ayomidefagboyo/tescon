# Upload and storage directories
UPLOAD_DIR=uploads
PROCESSED_DIR=processed

# Cleanup TTL in hours (0 = no cleanup)
CLEANUP_TTL_HOURS=24

# Maximum file size in MB
MAX_FILE_SIZE=100

# Enhanced REMBG via Kaggle (cost-effective processing)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
KAGGLE_NOTEBOOK_SLUG=daily-enhanced-rembg-processor
KAGGLE_AUTO_TRIGGER_ENABLED=true
KAGGLE_STRATEGY=batch_hourly

# Default output format
OUTPUT_FORMAT=PNG

# Batch processing settings (for large volumes like 50,000 images)
BATCH_SIZE=500
MAX_CONCURRENT=10

# Compression defaults
DEFAULT_COMPRESSION_QUALITY=85
DEFAULT_MAX_DIMENSION=2048

# Google Sheets Configuration (for part lookup)
GOOGLE_SHEETS_ID=your_sheet_id_here
GOOGLE_SHEETS_TAB_NAME=Sheet1
GOOGLE_CREDENTIALS_PATH=google-credentials.json

# Google Drive Configuration (for saving processed images)
GOOGLE_DRIVE_PARTS_FOLDER_ID=your_main_parts_folder_id_here

# Google Drive Authentication
# Option 1: Service Account (recommended for production)
GOOGLE_SERVICE_ACCOUNT_PATH=google-service-account.json

# Option 2: OAuth (for development)
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# Optional: Column name overrides (if your sheet uses different column names)
# GOOGLE_SHEETS_PART_NUMBER_COL=Symbol Number
# GOOGLE_SHEETS_DESCRIPTION_COL=Description
# GOOGLE_SHEETS_LOCATION_COL=Location
# GOOGLE_SHEETS_ITEM_NOTE_COL=Item Note

# Alternative: Base64 encoded credentials (for Render deployment)
# GOOGLE_CREDENTIALS_JSON=base64_encoded_json_string_here