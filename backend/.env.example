# Upload and storage directories
UPLOAD_DIR=uploads
PROCESSED_DIR=processed

# Cleanup TTL in hours (0 = no cleanup)
CLEANUP_TTL_HOURS=24

# Maximum file size in MB
MAX_FILE_SIZE=100

# Batch processing settings
BATCH_SIZE=500
MAX_CONCURRENT=10

# Compression defaults
DEFAULT_COMPRESSION_QUALITY=85
DEFAULT_MAX_DIMENSION=2048

# Excel catalog loaded at startup
EXCEL_FILE_PATH=data/Total EGTL Photo Project.xlsx
EXCEL_SHEET_NAME=Photo Data
EXCEL_LONG_TEXT_REF_PATH=data/EGTL_FINAL_23033_CLEANED.xlsx

# Cloudflare R2 storage (required for queued uploads and processed images)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_BUCKET_NAME=tescon-images

# GitHub Actions processing trigger
GITHUB_TOKEN=your_github_token
GITHUB_REPO_OWNER=ayomidefagboyo
GITHUB_REPO_NAME=tescon
GITHUB_WORKFLOW_FILE=process-images.yml
GITHUB_AUTO_TRIGGER_ENABLED=true
GITHUB_CHECK_INTERVAL=86400
GITHUB_JOB_AGE_THRESHOLD=3600
